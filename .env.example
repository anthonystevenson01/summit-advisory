# ─── Anthropic ───────────────────────────────────────────────────────────────
# Required. Used by all GTM Toolkit AI routes.
ANTHROPIC_API_KEY=sk-ant-...

# ─── Notion ──────────────────────────────────────────────────────────────────
# Optional. If set, /api/prompts fetches system prompts from a Notion database.
# The database should have columns: "Tool Key" (title) and "Prompt" (rich_text).
# Tool keys: positioning | problem | persona | moat | account
NOTION_TOKEN=secret_...
NOTION_PROMPTS_DB_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── Newsletter ──────────────────────────────────────────────────────────────
# Optional. If set, /api/newsletter/signup proxies email signups to this endpoint.
# The endpoint should accept POST { email: string }.
# If not set, the API returns { status: "coming_soon" } gracefully.
NEWSLETTER_ENDPOINT=https://your-email-provider.com/api/subscribe

# ─── Upstash Redis (Rate Limiting) ───────────────────────────────────────────
# Optional. If not set, rate limiting is disabled (no Redis calls).
# Get these from https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# ─── Vercel KV (alternative to Upstash) ──────────────────────────────────────
# These are used automatically if UPSTASH_* vars are not set.
KV_REST_API_URL=https://xxxx.kv.vercel-storage.com
KV_REST_API_TOKEN=AXxx...
